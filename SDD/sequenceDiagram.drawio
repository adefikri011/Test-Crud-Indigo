        <UserObject label="" plantUmlData="{&#xa;  &quot;data&quot;: &quot;@startuml\ntitle Sequence Diagram - Employee Management System\n\nactor User\nparticipant \&quot;UI / Main.js\&quot; as UI\nparticipant \&quot;ValidationHelper\&quot; as Validation\nparticipant \&quot;DataService\&quot; as Service\nparticipant \&quot;StorageHelper\&quot; as Storage\nparticipant \&quot;ModalComponent\&quot; as Modal\nparticipant \&quot;ConfirmComponent\&quot; as Confirm\nparticipant \&quot;AlertComponent\&quot; as Alert\nparticipant \&quot;TableComponent\&quot; as Table\nparticipant \&quot;LoadingComponent\&quot; as Loading\n\nUser -&gt; UI: Buka aplikasi\nUI -&gt; Loading: show()\nUI -&gt; Service: getAllEmployees()\nService -&gt; Storage: get(employees)\nStorage --&gt; Service: data karyawan\nService --&gt; UI: data karyawan\nUI -&gt; Table: renderTable(data)\nUI -&gt; Table: updateSummary()\nUI -&gt; Loading: hide()\n\nalt Cari / Filter\n  User -&gt; UI: Ketik search / pilih filter\n  UI -&gt; Service: searchEmployees()\n  Service --&gt; UI: hasil filter\n  UI -&gt; Table: renderTable(hasil)\n  UI -&gt; Table: updateSummary()\n\nelse Tambah Karyawan\n  User -&gt; UI: Klik Tambah Karyawan\n  UI -&gt; Modal: openCreateModal()\n  User -&gt; UI: Isi form dan submit\n  UI -&gt; Validation: validateEmployeeForm(data)\n  Validation --&gt; UI: valid / tidak valid\n\n  alt Data valid\n    UI -&gt; Loading: show()\n    UI -&gt; Service: addEmployee(data)\n    Service -&gt; Storage: set(employees, data baru)\n    Storage --&gt; Service: sukses\n    Service --&gt; UI: data baru\n    UI -&gt; Modal: closeModal()\n    UI -&gt; Table: renderTable()\n    UI -&gt; Table: updateSummary()\n    UI -&gt; Alert: showToast(\&quot;berhasil ditambahkan\&quot;)\n    UI -&gt; Loading: hide()\n  else Data tidak valid\n    UI -&gt; Alert: showToast(\&quot;validasi gagal\&quot;)\n  end\n\nelse Edit Karyawan\n  User -&gt; UI: Klik Edit\n  UI -&gt; Service: getEmployeeById(id)\n  Service --&gt; UI: data lama\n  UI -&gt; Modal: openEditModal(data)\n  User -&gt; UI: Ubah form dan submit\n  UI -&gt; Validation: validateEmployeeForm(data)\n  Validation --&gt; UI: valid / tidak valid\n\n  alt Data valid\n    UI -&gt; Loading: show()\n    UI -&gt; Service: updateEmployee(id, data)\n    Service -&gt; Storage: set(employees, data update)\n    Storage --&gt; Service: sukses\n    Service --&gt; UI: data update\n    UI -&gt; Modal: closeModal()\n    UI -&gt; Table: renderTable()\n    UI -&gt; Table: updateSummary()\n    UI -&gt; Alert: showToast(\&quot;berhasil diperbarui\&quot;)\n    UI -&gt; Loading: hide()\n  else Data tidak valid\n    UI -&gt; Alert: showToast(\&quot;validasi gagal\&quot;)\n  end\n\nelse Hapus Karyawan\n  User -&gt; UI: Klik Delete\n  UI -&gt; Confirm: show()\n  User -&gt; Confirm: Konfirmasi hapus\n\n  alt Setuju hapus\n    UI -&gt; Loading: show()\n    UI -&gt; Service: deleteEmployee(id)\n    Service -&gt; Storage: set(employees, data baru)\n    Storage --&gt; Service: sukses\n    Service --&gt; UI: berhasil\n    UI -&gt; Table: renderTable()\n    UI -&gt; Table: updateSummary()\n    UI -&gt; Alert: showToast(\&quot;berhasil dihapus\&quot;)\n    UI -&gt; Loading: hide()\n  else Batal\n    UI -&gt; Confirm: close()\n  end\nend\n\n@enduml&quot;,&#xa;  &quot;format&quot;: &quot;svg&quot;&#xa;}" id="iNTV69H766fghP1RDlo7-1">
          <mxCell parent="1" style="shape=image;noLabel=1;verticalAlign=top;aspect=fixed;imageAspect=0;image=data:image/svg+xml,;" vertex="1">
